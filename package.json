{
  "name": "retrovault",
  "version": "1.0.0",
  "packageManager": "pnpm@9.0.0",
  "type": "module",
  "private": true,
  "description": "Retro tech e-commerce - Monorepo",
  "scripts": {
    "stripe:login": "docker run --rm -it -v stripe_config:/root/.config/stripe stripe/stripe-cli login",
    "stripe:listen": "docker run --rm -it -v stripe_config:/root/.config/stripe stripe/stripe-cli listen --forward-to host.docker.internal:3000/webhooks/stripe",
    "build": "pnpm --filter @retrovault/shared build && turbo run build",
    "dev": "pnpm --filter @retrovault/shared build && pnpm dev:ordered",
    "dev:ordered": "concurrently --delay 5000 -k -p \"[{name}]\" -n \"CATALOG,GATEWAY,OTHERS\" -c \"cyan,magenta,yellow\" \"turbo dev --filter=@retrovault/catalog\" \"turbo dev --filter=@retrovault/gateway\" \"turbo dev --filter=!@retrovault/catalog --filter=!@retrovault/gateway\"",
    "test": "pnpm --filter @retrovault/shared build && turbo run test --concurrency=1",
    "test:cov": "pnpm --filter @retrovault/shared build && pnpm -r --workspace-concurrency=1 run test:cov",
    "db:push": "pnpm -r --workspace-concurrency=1 run db:push",
    "docker:up": "docker compose --env-file ./services/catalog/.env --env-file ./services/orders/.env --env-file ./services/payment/.env --env-file ./services/auth/.env up -d",
    "docker:down": "docker compose down -v"
  },
  "devDependencies": {
    "@testcontainers/kafka": "^11.14.0",
    "@testcontainers/postgresql": "^11.14.0",
    "@types/node": "^25.5.2",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^4.1.4",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "kafkajs": "^2.2.4",
    "prettier": "^3.8.1",
    "prisma": "6.19.2",
    "shx": "^0.4.0",
    "testcontainers": "^11.14.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "turbo": "^2.9.5",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@prisma/client": "6.19.2",
    "@retrovault/shared": "workspace:*",
    "uuid": "^10.0.0"
  },
  "pnpm": {
    "overrides": {
      "prisma": "6.19.2",
      "@prisma/client": "6.19.2",
      "@isaacs/brace-expansion": "5.0.1",
      "brace-expansion": "1.1.13",
      "minimatch@^3.0.0": "3.1.4",
      "minimatch@^10.0.0": "10.2.3",
      "rollup": "4.60.1",
      "vite": "7.3.2",
      "serialize-javascript": "7.0.5",
      "undici": "8.0.2",
      "socket.io-parser": "4.2.6",
      "effect": "3.20.0",
      "defu": "6.1.5",
      "picomatch": "4.0.4",
      "qs": "6.14.2",
      "ajv@^6.0.0": "6.14.0",
      "ajv@^8.0.0": "8.18.0"
    }
  }
}